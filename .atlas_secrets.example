# ATLAS GitHub push config — COPY this file to `.atlas_secrets` and fill it in.
# The real `.atlas_secrets` is gitignored, so it NEVER gets committed/pushed.
#
#   cp .atlas_secrets.example .atlas_secrets   (then edit .atlas_secrets)
#
# Get a token at: https://github.com/settings/tokens  (Fine-grained or Classic)
#   - Classic: tick the "repo" scope  (that's all push needs)
#   - Fine-grained: give it access to ONLY your Atlas repo, Contents: Read+Write
# Treat the token like a password. If it ever leaks, revoke it on that page.

GITHUB_USER=your-github-username
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=Atlas
GITHUB_BRANCH=main
